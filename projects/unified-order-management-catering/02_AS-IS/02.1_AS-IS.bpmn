    </bpmn:textAnnotation>
    <bpmn:association id="Association_1nl2fc2" associationDirection="None" sourceRef="Activity_1ddsoas" targetRef="TextAnnotation_04a5qbs" />
    <bpmn:textAnnotation id="TextAnnotation_1agktd9">
      <bpmn:text>Корзина / форма / звонок</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1gmtj7h" associationDirection="None" sourceRef="StartEvent_1nxrhx8" targetRef="TextAnnotation_1agktd9" />
    <bpmn:textAnnotation id="TextAnnotation_1om0job">
      <bpmn:text>Проверяется дата, время, доступность всех позиций из меню (из-за ручного управления датами возможны ошибки)</bpmn:text>
