    <bpmn:textAnnotation id="TextAnnotation_04a5qbs">
      <bpmn:text>Бизнес-правило: заказ принимается не менее чем за 24 часа до события
event time - now ≥ 24ч
Календарь отображает только доступные даты (актуальность дат не гарантирована)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_078chc7">
      <bpmn:text>на Google Drive</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1973vlw">
      <bpmn:text>на Google Drive</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_13vwk77">
