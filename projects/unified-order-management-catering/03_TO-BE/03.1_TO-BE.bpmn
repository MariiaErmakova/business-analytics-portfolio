    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1chays4">
      <bpmn:text>payment_status = paid
Order Draft → Order</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0lgesrl">
