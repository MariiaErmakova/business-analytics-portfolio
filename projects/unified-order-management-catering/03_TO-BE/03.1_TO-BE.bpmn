    <bpmn:textAnnotation id="TextAnnotation_0z8kvxq">
      <bpmn:text>Бизнес-правило: заказ принимается не менее чем за 24 часа до события
event time - now ≥ 24ч
Календарь отображает только доступные даты</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1xarqzo">
      <bpmn:text>payment_status = paid</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0170hpt">
